# ============================================================================
# Legal Scout — Environment Configuration
# ============================================================================
# cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32       → JWT_SECRET_KEY
#   openssl rand -base64 24    → DB_PASS
# ============================================================================

# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Authentication
ADMIN_EMAIL=admin@legalscout.com
ADMIN_PASSWORD=change-this-password
JWT_SECRET_KEY=CHANGE_ME

# Database
DB_USER=scout
DB_PASS=change-this-db-password
DB_DATABASE=legalscout

# Port (change if 80 is taken)
PORT=80
