# Required (default configured for OpenAI)
OPENAI_API_KEY=sk-***

# Optional: Use a different model provider
# ANTHROPIC_API_KEY=sk-ant-***
# GOOGLE_API_KEY=***

# Exa API key for web research
# EXA_API_KEY=***

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# =============================================================================
# Connectors (optional - Scout uses mock data by default)
# =============================================================================

# AWS S3 (primary connector)
# AWS_ACCESS_KEY_ID=***
# AWS_SECRET_ACCESS_KEY=***
# AWS_REGION=us-east-1

# Google Drive
# GOOGLE_CREDENTIALS=/path/to/service-account.json

# Notion
# NOTION_API_KEY=secret_***

# Slack
# SLACK_BOT_TOKEN=xoxb-***
